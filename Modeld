from langchain_openai import ChatOpenAI, OpenAIEmbeddings
from config import OPENAI_API_KEY, EMBEDDING_MODEL, LLM_MODEL

def get_llm():
    return ChatOpenAI(
        model=LLM_MODEL,
        api_key=OPENAI_API_KEY,
        temperature=0.2
    )

def get_embeddings():
    return OpenAIEmbeddings(
        model=EMBEDDING_MODEL,
        api_key=OPENAI_API_KEY
    )
