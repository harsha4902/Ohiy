import streamlit as st

from graph.rag_graph import build_graph


graph = build_graph()


st.set_page_config(layout="wide")

st.title("Cyber Vulnerability RAG Assistant")


left, right = st.columns([1,2])


with left:

    st.header("Vulnerability Summary")

    if "summary" not in st.session_state:
        st.session_state.summary = ""

    st.write(st.session_state.summary)


with right:

    st.header("Chat")

    query = st.text_input("Ask about CVE vulnerability")

    if st.button("Analyze"):

        result = graph.invoke({
            "query": query
        })

        answer = result["result"]

        st.session_state.summary = answer[:400]

        st.write(answer)
